# Author: Simge Ekiz
# License: MIT

# If not running interactively, don't do anything
case $- in
  *i*) ;;
    *) return;;
esac

source_if_exists() {
  [ -r "$1" ] && . "$1"
}

# === PATH and environment variables ===
source_if_exists "$HOME/.dotfiles/bash/env.sh"

# === Tool initialization ===
# -- nvm lazy-loading
export NVM_DIR="$HOME/.nvm"

lazy_load_nvm() {
  [ -s "$NVM_DIR/nvm.sh" ] || return 1

  unset -f nvm node npm npx lazy_load_nvm
  \. "$NVM_DIR/nvm.sh" || return 1

  if [ -s "$NVM_DIR/bash_completion" ]; then
    \. "$NVM_DIR/bash_completion"
  fi
}

if [ -s "$NVM_DIR/nvm.sh" ]; then
  nvm() {
    lazy_load_nvm && nvm "$@"
  }

  node() {
    lazy_load_nvm && node "$@"
  }

  npm() {
    lazy_load_nvm && npm "$@"
  }

  npx() {
    lazy_load_nvm && npx "$@"
  }
fi

# -- conda initialization ===
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('$HOME/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "$HOME/anaconda3/etc/profile.d/conda.sh" ]; then
        . "$HOME/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup

# -- lesspipe initialization
if command -v lesspipe >/dev/null 2>&1; then
  eval "$(SHELL=/bin/sh lesspipe)"
fi

# === Shell behavior (history, options) ===
# History settings
HISTCONTROL=ignoreboth       # ignore duplicates & lines starting with space
shopt -s histappend          # append to history, don't overwrite
HISTSIZE=1000                # for setting history length see HISTSIZE
HISTFILESIZE=2000            # and HISTFILESIZE in bash(1)

# Shell options
shopt -s checkwinsize        # update LINES and COLUMNS after resize
# shopt -s globstar           # enable '**' in pathname expansion (optional)

# === Functions ===
for file in "$HOME/.dotfiles/functions"/*.sh; do
  [ -r "$file" ] && . "$file"
done

# === Aliases ===
# Load alias definitions.
source_if_exists "$HOME/.dotfiles/bash/bash_aliases.sh"
source_if_exists "$HOME/.dotfiles/tmux/tmux_aliases.sh"
source_if_exists "$HOME/.dotfiles/git/git_aliases.sh"

# === Prompt / PS1 ===
source_if_exists "$HOME/.dotfiles/bash/prompt.sh"

# === Completion ===
source_if_exists "$HOME/.dotfiles/bash/completion.sh"
