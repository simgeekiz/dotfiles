# ~/.dotfiles/zsh/.zshrc

### === Load modular Zsh setup === ###

# Source .zprofile first (optional, for non-login shells)
[[ -f $HOME/.dotfiles/zsh/zprofile ]] && source $HOME/.dotfiles/zsh/zprofile

# Load Config
[[ -f $HOME/.dotfiles/zsh/config.zsh ]] && source $HOME/.dotfiles/zsh/config.zsh

# Load Aliases 
[[ -f $HOME/.dotfiles/zsh/zsh_aliases.zsh ]] && source $HOME/.dotfiles/zsh/zsh_aliases.zsh

# Load Key Bindings 
[[ -f $HOME/.dotfiles/zsh/key-bindings.zsh ]] && source $HOME/.dotfiles/zsh/key-bindings.zsh

# Load Completion
[[ -f $HOME/.dotfiles/zsh/completion.zsh ]] && source $HOME/.dotfiles/zsh/completion.zsh

# Import functions
for file in $HOME/.dotfiles/functions/*.zsh(N); do
  source $file
done

# Load Prompt 
[[ -f $HOME/.dotfiles/zsh/prompt.zsh ]] && source $HOME/.dotfiles/zsh/prompt.zsh

