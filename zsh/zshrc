# === NVM (Node Version Manager) setup ===
export NVM_DIR="$HOME/.nvm"

# Load NVM if available
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  # Only load once (idempotent)
  if ! (( $+functions[nvm] )); then
    source "$NVM_DIR/nvm.sh"
  fi
fi

# Auto-load Node version from .nvmrc if it exists
autoload -U add-zsh-hook

load-nvmrc() {
  # Find desired version
  local nvm_version desired_node

  if [[ -f .nvmrc ]]; then
   # If a .nvmrc file exists, use its version
    desired_node=$(<.nvmrc)
  else
    # Otherwise, automatically use the latest installed Node version
    local latest_node
    latest_node=$(/bin/ls -1 "$NVM_DIR/versions/node" | sort -V | tail -1)
    if [[ -n "$latest_node" ]]; then
      nvm use "$latest_node" > /dev/null
    fi
  fi

  # Only switch if different from current
  if [[ -n "$desired_node" ]] && [[ "$desired_node" != "$(nvm current)" ]]; then
    nvm use "$desired_node" > /dev/null 2>&1
  fi
}

# Hook to run function every time you change directories (safe: avoid duplicates)
if ! (( $+functions[load_nvmrc_hook_added] )); then
  add-zsh-hook chpwd load-nvmrc
  typeset -g load_nvmrc_hook_added=1
fi

# Run once at shell startup
load-nvmrc