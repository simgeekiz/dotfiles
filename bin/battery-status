#!/usr/bin/env bash
#
# A quick little indicator for battery status on your Mac laptop, suitable for display in your prompt.
# Usage: battery-status
#
# Author: Simge Ekiz
# License: MIT

set -euo pipefail

RED="\033[31m"
GREEN="\033[32m"
ORANGE="\033[38;5;214m"
YELLOW="\033[33m"
RESET="\033[0m"

# Defaults
SHORT=0

usage() {
  cat <<EOF
Usage: battery-status [options]

Options:
  -h, --help        Show this help message
  -s, --short       Short output (minimal format)

Description:
  Displays battery status for macOS and Linux systems.

Examples:
  battery-status
  battery-status --short
EOF
}

parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      -s|--short)
        SHORT=1
        shift
        ;;
      *)
        printf "❗ Unknown option: %s\n\n" "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  done
}

macos_battery_info() {
  # Check if pmset command is available
  if ! command -v pmset &> /dev/null; then
    echo "❗ pmset command not found. Please ensure you are running this on a macOS system."
    return 1
  fi

  # Get the battery status using pmset
  local battery_status
  if ! battery_status=$(pmset -g batt 2>/dev/null); then
    printf "❗ Failed to read battery status\n" >&2
    return 1
  fi

  # Defaults (avoid unbound vars with set -u)
  local ac_status="🔋 On Battery"
  local charging_status="unknown"
  local battery_capacity="?"
  local percent_num=0
  local color="$RESET"
  local time_remaining="⌛️"

  # AC status (power source)
  [[ "$battery_status" == *"AC Power"* ]] && ac_status="🔌 On AC"

  # Charging state (safe against grep failure)
  charging_status=$(grep -Eo 'charging|discharging|charged' <<<"$battery_status" 2>/dev/null || printf "unknown")

 # Battery percentage
  if battery_capacity=$(grep -Eo '[0-9]{1,3}%' <<<"$battery_status" 2>/dev/null); then
    percent_num=${battery_capacity%\%}
  fi

  # Color selection (guard arithmetic)
  if [[ "$percent_num" =~ ^[0-9]+$ ]]; then
    if (( percent_num <= 20 )); then
      color=$RED
    elif (( percent_num <= 50 )); then
      color=$ORANGE
    elif (( percent_num <= 70 )); then
      color=$YELLOW
    else
      color=$GREEN
    fi
  fi

  # Time remaining
  local raw_time
  raw_time=$(grep -Eo '[0-9]+:[0-9]+' <<<"$battery_status" 2>/dev/null || true)

  if [[ -z "$raw_time" ]]; then
    time_remaining="⌛️"
  elif [[ "$raw_time" == "0:00" ]]; then
    time_remaining="⚡️"
  else
    time_remaining="⌛️ $raw_time"
  fi

  # Short output
  if [[ "${SHORT:-0}" -eq 1 ]]; then
    printf "%s%%\n" "$percent_num"
    return 0
  fi

  # Final output (no color bleed)
  printf "%s - %s (%b%s%b) - %s\n" \
    "$ac_status" \
    "$charging_status" \
    "$color" \
    "$battery_capacity" \
    "$RESET" \
    "$time_remaining"
}

linux_battery_info(){
  # Check if the battery and AC paths exist
  # Find battery path safely
  local BAT_PATH=""
  local AC_PATH=""

  for p in /sys/class/power_supply/BAT*; do
    [[ -d "$p" ]] && BAT_PATH="$p" && break
  done

  for p in /sys/class/power_supply/A*; do
    [[ -d "$p" ]] && AC_PATH="$p" && break
  done

  if [[ -z "$BAT_PATH" ]]; then
    printf "❗ No battery found\n" >&2
    return 1
  fi

  # Defaults (safe with set -u)
  local charging_status="unknown"
  local battery_capacity="?"
  local percent_num=0
  local ac_online=0
  local ac_status="🔋 On Battery"
  local color="$RESET"

  # Read charging status safely
  if [[ -r "$BAT_PATH/status" ]]; then
    charging_status=$(<"$BAT_PATH/status")
  fi

  # Read capacity safely
  if [[ -r "$BAT_PATH/capacity" ]]; then
    battery_capacity=$(<"$BAT_PATH/capacity")
    percent_num="$battery_capacity"
  fi

  # Validate number before arithmetic
  if [[ "$percent_num" =~ ^[0-9]+$ ]]; then
    if (( percent_num <= 20 )); then
      color=$RED
    elif (( percent_num <= 50 )); then
      color=$ORANGE
    elif (( percent_num <= 70 )); then
      color=$YELLOW
    else
      color=$GREEN
    fi
  fi

  # Read AC status safely (1 if plugged in, 0 if not)
  if [[ -n "$AC_PATH" && -r "$AC_PATH/online" ]]; then
    ac_online=$(<"$AC_PATH/online")
  fi
  # Fancy output for AC status (power source)
  if [[ "$ac_online" == "1" ]]; then
    ac_status="🔌 On AC"
  fi

  # Short output
  if [[ "${SHORT:-0}" -eq 1 ]]; then
    printf "%s%%\n" "$percent_num"
    return 0
  fi

  # Output (no color bleed)
  printf "%s - %s (%b%s%%%b)\n" \
    "$ac_status" \
    "$charging_status" \
    "$color" \
    "$battery_capacity" \
    "$RESET"
}

main() {
  parse_args "$@"

  case "$(uname -s)" in
    Darwin*)
      macos_battery_info
      ;;
    Linux*)
      linux_battery_info
      ;;
    *)
      printf "❗ Unsupported OS: %s\n" "$(uname -s)" >&2
      return 1
      ;;
  esac
}

main "$@"