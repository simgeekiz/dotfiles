#!/usr/bin/env bash
#
# File: ~/.dotfiles/bin/ssh-key
# Setup SSH key if not present
# Usage: ssh-key
#
# Author: Simge Ekiz
# License: MIT

set -euo pipefail
SSHDIR="${HOME}/.ssh"
script_name="${0##*/}"

# === Usage ===
usage() {
  cat <<EOF
Usage: $script_name [options]

Options:
  --help, -h   Show this help message

Description:
  Checks for an existing SSH key. If none exists,
  generates a new ed25519 key and adds it to ssh-agent.
EOF
}

# === Parse args ===
parse_args() {
  if [[ $# -gt 0 ]]; then
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf "❗ Unknown option: %s\n\n" "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  fi
}

# === 🔍 Check for existing SSH key ===
find_existing_ssh_key() {
  local key path
  for key in ed25519 ecdsa rsa; do
    path="$SSHDIR/id_${key}.pub"
    if [[ -f "$path" ]]; then
      printf '%s\n' "$path"
      return 0
    fi
  done
  return 1
}


# === 🧠 Generate SSH key ===
generate_key() {
  echo "🔐 No SSH key found. Generating a new one..."
  read -r "📧 Enter your email for the SSH key: " EMAIL

  ssh-keygen -t ed25519 -C "$EMAIL"

  # Ensure ssh-add exists
  if ! command -v ssh-add >/dev/null 2>&1; then
    echo "ssh-add not found"
    exit 1
  fi

  # Start agent if no keys are loaded
  if ! ssh-add -l >/dev/null 2>&1; then
    eval "$(ssh-agent -s)" >/dev/null
  fi

  # Add the new key to the agent
  ssh-add "$SSHDIR/id_ed25519"

  echo "✅ SSH key generated and added to ssh-agent."
}


# === Main ===
main() {
  parse_args "$@"

  # If no key exists, generate a new one
  local pubkey
  if ! pubkey="$(find_existing_ssh_key)"; then
    generate_key
    pubkey="$SSHDIR/id_ed25519.pub"
  fi

  # Final safety check
  if [[ ! -f "$pubkey" ]]; then
    echo "Failed to locate SSH public key."
    exit 1
  fi

  echo
  echo "🔑 Your SSH public key:"
  cat "$pubkey"
  if command -v pbcopy >/dev/null 2>&1; then
    pbcopy < "$pubkey"
  elif command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard < "$pubkey"
  fi

}

main "$@"