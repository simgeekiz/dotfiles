#!/usr/bin/env bash
#
# Prints the IP address of the machine.
# Usage: myip
#
# Author: Simge Ekiz
# License: MIT

set -euo pipefail

# ---------- usage ----------
usage() {
  cat <<EOF
Usage: myip [options]

Options:
  -h, --help      Show this help message

Description:
  Prints the primary local IPv4 address (Linux + macOS).

Examples:
  myip
EOF
}

# ---------- args ----------
parse_args() {
  if [[ $# -gt 0 ]]; then
    case "$1" in
      -h|--help)
        usage
        exit 0
        ;;
      *)
        printf "❗ Unknown option: %s\n\n" "$1" >&2
        usage >&2
        exit 1
        ;;
    esac
  fi
}

# ---------- linux ----------
get_ip_linux() {
  if command -v ip >/dev/null 2>&1; then
    ip route get 1 2>/dev/null \
      | awk '{print $7; exit}'
  elif command -v ifconfig >/dev/null 2>&1; then
    ifconfig | awk '/inet / && $2 != "127.0.0.1" {print $2; exit}'
  else
    printf "❗ No suitable command found\n" >&2
    return 1
  fi
}


# ---------- macOS ----------
get_ip_macos() {
  local ip=""

  ip=$(route get default 2>/dev/null \
    | awk '/interface: / {print $2}' \
    | xargs -I{} ipconfig getifaddr {} 2>/dev/null || true)

  if [[ -z "$ip" ]]; then
    ip=$(ifconfig | awk '/inet / && $2 != "127.0.0.1" {print $2; exit}')
  fi

  [[ -z "$ip" ]] && {
    printf "❗ No IP address found\n" >&2
    return 1
  }

  printf "%s\n" "$ip"
}


# ---------- main ----------
main() {
  parse_args "$@"

  local os
  os="$(uname -s)"

  case "$os" in
    Linux*) get_ip_linux;;
    Darwin*) get_ip_macos;;
    *)
      printf "❗ Unsupported OS: %s\n" "$os" >&2
      return 1
      ;;
  esac
}

main "$@"