#!/usr/bin/env bash
#
# Description:
# Prints ANSI colors in the terminal.
# - Standard ANSI colors (0-7 normal and 8-15 bright)
# - 256-color palette (0–255)
# - 6x6x6 color cube (16–231)
# - Grayscale colors: Print grayscale colors (232–255)
# - Supports flags: --standard, --all, --cube
# - Useful for choosing terminal color codes for scripts and themes.
#
# Author: Simge Ekiz
# License: MIT

set -euo pipefail

script_name="${0##*/}"
PRINT_STANDARD=false
PRINT_ALL=false
PRINT_CUBE=false

usage() {
  cat <<EOF
Usage: $script_name [OPTIONS]

Options:
  -h, --help       Show this help message
  --standard          Print standard ANSI colors (0–7) with codes
  --all               Print all 256 ANSI colors (0–255)
  --cube              Print the 6x6x6 ANSI color cube (16–231)
EOF
}

parse_args() {
  if [[ $# -eq 0 ]]; then
    PRINT_STANDARD=true
    PRINT_ALL=true
    PRINT_CUBE=true
    return
  fi
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -h|--help) usage; exit 0 ;;
      --standard) PRINT_STANDARD=true ;;
      --all) PRINT_ALL=true ;;
      --cube) PRINT_CUBE=true ;;
      *)
        echo "❗ Unknown option: $1" >&2
        usage
        exit 1
        ;;
    esac
    shift
  done
}

# 🎨 Function: Print standard ANSI colors
# -----------------------
print_standard_colors_with_codes() {
  local colors=(
    "Black:30"
    "Red:31"
    "Green:32"
    "Yellow:33"
    "Blue:34"
    "Magenta:35"
    "Cyan:36"
    "White:37"
  )
  echo
  echo "Standard ANSI Colors (0–7):"
  # echo "Color codes use the form: \033[SELECTEDCOLORCODEm Bold:\033[1;SELECTEDCOLORCODEm";
  for c in "${colors[@]}"; do
    local name="${c%%:*}"  # Color name
    local code="${c##*:}"  # ANSI code

    # Normal color sample
    printf "%s \033[%sm%s\033[0m (\033[1;%sm%s\033[0m)\n" "$code" "$code" "$name" "$code" "$name"

    # # Bold / bright variant
    # printf "  (Bold: \033[1;%sm%s\033[0m)\n" "$code" "$name"
  done
  # echo "Reset code is: \033[0m  # resets all colors/styles back to default"
  echo
}

# 🎨 Function: Full 0–255 palette
print_all_colors() {
  echo
  echo
  echo "Standard ANSI Colors:"
  for i in {0..255}; do
    printf "\033[38;5;%sm%3s\033[0m " "$i" "$i"
    printf "\033[1;38;5;%sm%3s\033[0m " "$i" "$i"

    (( (i + 1) % 8 == 0 )) && echo
  done
  echo
}

# 🎨 Function: 6x6x6 color cube
print_color_cube() {
  echo
  echo
  echo "ANSI 256-color cube:"

  for r in {0..5}; do
    for g in {0..5}; do
      for b in {0..5}; do
        color=$((16 + r * 36 + g * 6 + b))
        printf "\033[38;5;%sm%3s\033[0m " "$color" "$color"
        printf "\033[48;5;%sm%3s\033[0m " "$color" "$color"
      done
      echo
    done
    echo
  done
}

# 🚀 Main
main() {
  parse_args "$@"

  # Execute functions only if their flag is true
  $PRINT_STANDARD && print_standard_colors_with_codes
  $PRINT_ALL && print_all_colors
  $PRINT_CUBE && print_color_cube
}

main "$@"
