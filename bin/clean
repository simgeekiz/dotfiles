#!/usr/bin/env bash
#
# Empties the trash on all mounted volumes.
# Usage:  clean
# credit: https://github.com/dikiaap/dotfiles
#
# Author: Simge Ekiz
# License: MIT

set -e  # Exit on error

script_name="${0##*/}"

MAGENTA="\033[35m"
RESET="\033[0m"

# Print usage message.
usage() {
  cat <<EOF
    Usage: $script_name [OPTIONS]

    Options:
      --help, -h       Show this help message
      --trash, -t      Clean system Trash (Linux/macOS)
      --packages, -p   Auto-clean package manager cache
      --all            Do both update and clean (default)
EOF
}

# === Parse arguments ===
parse_args() {
  if [[ "$#" -eq 0 ]]; then
    clean_trash
    clean_package_cache
    return
  fi

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --help | -h | -help)
        usage
        exit 0
        ;;
      --trash | -t | -trash)
        clean_trash
        ;;
      --packages|-p)
        clean_package_cache
        ;;
      --all|-a)
        clean_trash
        clean_package_cache
        ;;
      *)
        printf "❗ Unknown option: $1\n"
        usage
        exit 1
        ;;
    esac
    shift
  done
}

# Since some programs are installed in non-root directories,
# don't run this script as root to avoid permission conflict.
if [[ $EUID -eq 0 ]]; then
    printf "Don't run this script as root"
    exit 1
fi

clean_trash() {
  printf "${MAGENTA}🗑️ Cleaning system Trash...${RESET}"
  case "$(uname -s)" in
    Darwin*)
      sudo rm -rf ~/.Trash/*
      sudo rm -rf /Volumes/*/.Trashes/*
      sudo rm -rf /private/var/log/asl/*.asl
      ;;
    Linux*)
      sudo rm -rf "$HOME/.local/share/Trash/"* 2>/dev/null || true
      ;;
    *)
      printf "❗ Unsupported OS: $(uname -s)." >&2
      exit 1
      ;;
  esac
}

clean_package_cache() {
  printf "📦 Detecting package manager..."
  if command -v apt >/dev/null 2>&1; then
    printf "${MAGENTA}🧼 Cleaning APT...${RESET}"
    sudo apt clean
    sudo apt autoclean
    sudo apt autoremove -y
  elif command -v dnf >/dev/null 2>&1; then
    printf "${MAGENTA}🧼 Cleaning DNF...${RESET}"
    sudo dnf autoremove -y
    sudo dnf clean all
  elif command -v yum >/dev/null 2>&1; then
    printf "${MAGENTA}🧼 Cleaning YUM...${RESET}"
    sudo yum autoremove -y
    sudo yum clean all
  elif command -v pacman >/dev/null 2>&1; then
    printf "${MAGENTA}🧼 Cleaning Pacman...${RESET}"
    sudo pacman -Rns $(pacman -Qtdq) || true
    sudo pacman -Sc --noconfirm
  elif command -v zypper >/dev/null 2>&1; then
    printf "${MAGENTA}🧼 Cleaning Zypper...${RESET}"
    sudo zypper clean --all
  elif command -v brew >/dev/null 2>&1; then
    printf "${MAGENTA}🍺 Cleaning Homebrew...${RESET}"
    brew cleanup -s
    brew autoremove
  else
    printf "${MAGENTA}❗ No supported package manager found.${RESET}"
  fi
}

main() {
  parse_args "$@"
}

main "$@"
