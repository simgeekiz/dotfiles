#!/usr/bin/env bash
#
# File: ~/.dotfiles/bin/turnonheadphones
# For headphone to work properly
# Usage: turnonheadphones
#
# Author: Simge Ekiz
# License: MIT

#  HEADPHONES (functions)

set -euo pipefail

function run_pafile() {
  command -v nc >/dev/null 2>&1 || { echo "❗ nc not found"; return 1; }
  if [[ -x "$pafile" ]]; then
    bash "$pafile" | nc termbin.com 9999
  else
    echo "Script is not executable or not found."
    return 1
  fi
}

main() {
  # Check if the script exists and is executable
  pafile="$HOME/.dotfiles/privates/pa-info"
  hash_file="$HOME/.dotfiles/privates/pa-info.sha256"
  expected_hash=$(awk '{print $1}' "$hash_file")

  if [[ -e $pafile ]]; then
    run_pafile
    return
  
  command -v curl >/dev/null 2>&1 || { echo "❗ curl not found"; return 1; }
  command -v bash >/dev/null 2>&1 || { echo "❗ bash not found"; return 1; }

  echo "Warning: executing remote script\n" 

  curl -fsSL "https://gitlab.freedesktop.org/pulseaudio/pulseaudio/raw/master/src/utils/pa-info?inline=false" -o "$pafile"
  chmod +x "$pafile"

  [[ -s "$pafile" ]] || { echo "Download failed or empty script."; rm -f "$pafile"; return 1; }

  # Cross-platform SHA256
  if command -v sha256sum >/dev/null 2>&1; then
    actual_hash=$(sha256sum "$pafile" | awk '{print $1}')
  elif command -v shasum >/dev/null 2>&1; then
    actual_hash=$(shasum -a 256 "$pafile" | awk '{print $1}')
  else
    echo "❗ No SHA256 utility found (sha256sum or shasum)"
    return 1
  fi

  if [[ "$actual_hash" != "$expected_hash" ]]; then
    echo "⚠️  Hash mismatch!"
    echo "Expected: $expected_hash"
    echo "Actual:   $actual_hash"
    echo "Script may have been tampered with. Aborting."
    return 1
  fi

  echo "✅ Hash verified. Running script..."
  run_pafile
}

main "$@"